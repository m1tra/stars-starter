{
  "name": "mit-starter",
  "packageManager": "yarn@4.9.2",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "turbo": "^2.5.5"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "rm -rf node_modules && yarn",
    "db:generate": "turbo run generate --filter=db",
    "db:migrate": "turbo run migrate --filter=db"
  }
}
